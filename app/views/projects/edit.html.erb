<div class="max-w-lg mx-auto mt-8 p-4">
  <h1 class="text-2xl font-bold mb-6">Edit Project</h1>

  <%= form_with model: @project, class: "space-y-4" do |f| %>
    <% if @project.errors.any? %>
      <div class="bg-red-100 p-3 rounded">
        <% @project.errors.full_messages.each do |msg| %>
          <p class="text-red-700 text-sm"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium" %>
      <%= f.text_field :name, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium" %>
      <%= f.text_area :description, rows: 4, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <%= f.submit class: "bg-blue-500 text-white px-4 py-2 rounded cursor-pointer" %>
  <% end %>
</div>
