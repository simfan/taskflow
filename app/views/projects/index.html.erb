<div class="max-w-4xl mx-auto mt-8 p-4">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">My Projects</h1>
    <%= link_to "New Project", new_project_path, class: "bg-blue-500 text-white px-4 py-2 rounded" %>
  </div>

  <% if @projects.empty? %>
    <p class="text-gray-500">No projects yet. Create your first one!</p>
  <% else %>
    <div class="grid gap-4">
      <% @projects.each do |project| %>
        <div class="border rounded-lg p-4 shadow-sm">
          <div class="flex justify-between">
            <h2 class="text-lg font-semibold"><%= link_to project.name, project, class: "text-blue-600 hover:underline" %></h2>
            <div class="space-x-2">
              <%= link_to "Edit", edit_project_path(project), class: "text-sm text-gray-500" %>
              <%= link_to "Delete", project, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-sm text-red-500" %>
            </div>
          </div>
          <p class="text-gray-600 mt-1"><%= project.description %></p>
          <p class="text-sm text-gray-400 mt-2"><%= project.tasks.count %> tasks</p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>