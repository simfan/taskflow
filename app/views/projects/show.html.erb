<div class="max-w-4xl mx-auto mt-8 p-4">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold"><%= @project.name %></h1>
    <%= link_to "Add Task", new_project_task_path(@project), class: "bg-green-500 text-white px-4 py-2 rounded" %>
  </div>

  <p class="text-gray-600 mb-6"><%= @project.description %></p>

  <% if @tasks.empty? %>
    <p class="text-gray-500">No tasks yet.</p>
  <% else %>
    <div class="grid gap-3">
      <% @tasks.each do |task| %>
        <div class="border rounded-lg p-4 flex justify-between items-center">
          <div>
            <h3 class="font-medium"><%= task.title %></h3>
            <span class="text-xs px-2 py-1 rounded-full
              <%= task.todo? ? 'bg-gray-200' : task.in_progress? ? 'bg-yellow-200' : 'bg-green-200' %>">
              <%= task.status.humanize %>
            </span>
            <% if task.due_date %>
              <span class="text-sm text-gray-500 ml-2">Due: <%= task.due_date.strftime("%b %d, %Y") %></span>
            <% end %>
          </div>
          <div class="space-x-2">
            <%= link_to "Edit", edit_task_path(task), class: "text-sm text-gray-500" %>
            <%= link_to "Delete", task, data: { turbo_method: :delete, turbo_confirm: "Sure?" }, class: "text-sm text-red-500" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
