<div class="max-w-lg mx-auto mt-8 p-4">
  <h1 class="text-2xl font-bold mb-6">New Task</h1>

  <%= form_with model: @task, url: project_tasks_path(@project), class: "space-y-4" do |f| %>
    <div>
      <%= f.label :title, class: "block text-sm font-medium" %>
      <%= f.text_field :title, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium" %>
      <%= f.text_area :description, rows: 3, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :due_date, class: "block text-sm font-medium" %>
      <%= f.date_field :due_date, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium" %>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full border rounded px-3 py-2" %>
    </div>

    <%= f.submit class: "bg-green-500 text-white px-4 py-2 rounded cursor-pointer" %>
  <% end %>
</div>
